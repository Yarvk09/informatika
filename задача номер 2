a = int(input()) ## вводим кол-во циклов (кол-во чисел)
s = 0 ## сумма чисел изначальна =0

if a < 100: ## смотрим чтобы кол-во чисел было меньше 100
    for i in range(a): ## создаём цикл с колличеством = a
        b = int(input()) ## вводим чило 
        if b < 300: ## смотрим чтобы само число b было меньше 300 
            if b % 6 == 0: ## смотрим чтобы число b было кратно 6 
                s += b ## если кратно 6, то записываем в сумму

print (s) ## выводим финальное число
