x = int(input()) # просто водим число с клавиатуры
s = 0 # создам сумму чисел 

while x != 0: # так как сказано, что неизвестная длинна (просто не = 0)
     if x % 6 == 0 and x % 10 == 4: # смотрим чтобы число было кратно 6 и оканчивалось на 4
         s += x # если условие выше выполняется, то добавляем это число к сумме
     x = int(input()) # вводим новое число так как прошлый ввод был одноразовый (не входит в цикл)

print(s) # выводим сумму когда закончится цикл


