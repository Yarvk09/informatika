a = int(input()) #кол-во чисел
con = 0 # просто создаем обозначение для счетчика

if a < 1000: # смотрим чтобы число a было меньше 1000
    for i in range(a): # создам цикл с который выполняется a кол-во раз
        x = int(input()) # вводим число
        if x < 30000: # смотрим чтобы введнное число было меньше 30000
            if x % 4 == 0: # смотрим чтобы x был кратен 4
                con += 1 # если кратен то в счтччик добавляем +1 

print(con) # выводим итоговое значение


